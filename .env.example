# Môi trường Sui (testnet, devnet, hoặc mainnet)
SUI_NETWORK=testnet
SUI_MNEMONIC=your_mnemonic

# ID của package đã triển khai trên Sui
SUI_PACKAGE_ID=your_package_id

# API Keys cho các nền tảng xã hội
GITHUB_API_KEY=your_github_api_key
LINKEDIN_API_KEY=your_linkedin_api_key
FARCASTER_API_KEY=your_farcaster_api_key
DISCORD_API_KEY=your_discord_api_key
RAPIDAPI_API_KEY=your_twitter_api_key
TUSKY_API_KEY=your_tusky_api_key
XAI_API_KEY=your_xai_api_key

# Database connection string
DATABASE_URL=postgres://username:password@host:port/database

# Port cho server Express (mặc định là 5000)
PORT=5000

# JWT Secret
JWT_SECRET=your_jwt_secret
